# Affordmed Backend Configuration

# Test Server URL
AFFORDMED_API_URL=http://20.207.122.201/evaluation-service

# API Authentication Token (obtained after registration)
AFFORDMED_API_TOKEN=your_access_token_here

# Logging Token (can be the same as API_TOKEN)
AFFORDMED_LOG_TOKEN=your_access_token_here

# Client credentials (for reference, not needed for API calls)
AFFORDMED_CLIENT_ID=your_client_id_here
AFFORDMED_CLIENT_SECRET=your_client_secret_here

# Priority Inbox Configuration
AFFORDMED_PRIORITY_LIMIT=10
